# Copy this file to .env and fill in the values
# cp .env.example .env

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Comma-separated list of allowed hostnames (add your domain/IP here)
ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Comma-separated list of allowed CORS origins (used when DEBUG=False)
CORS_ALLOWED_ORIGINS=http://localhost
# Comma-separated list of trusted origins for CSRF checks
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# PostgreSQL
DB_NAME=cinema_db
DB_USER=cinema_user
DB_PASSWORD=cinema_pass

# Admin account (created automatically on first boot)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cinema.local
ADMIN_PASSWORD=change-me-admin-password

# Staff account (created automatically on first boot)
STAFF_USERNAME=staff
STAFF_EMAIL=staff@cinema.local
STAFF_PASSWORD=change-me-staff-password

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key
